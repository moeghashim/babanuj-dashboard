# Public catalog source.
SHOPIFY_STORE_DOMAIN=babanuj.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# Dedicated dashboard snapshot database. Do not reuse the auth database unless
# you intentionally want metrics tables in that database.
# Vercel Neon with the DASHBOARD_DATABASE prefix creates
# DASHBOARD_DATABASE_DATABASE_URL automatically.
DASHBOARD_DATABASE_URL=
DASHBOARD_DATABASE_DATABASE_URL=

# Required by /api/cron/sync. Vercel Cron sends this as a bearer token.
# The cron schedule is every 4 hours: 0 */4 * * *
CRON_SECRET=

# Revenue and order metrics.
SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOPIFY_ADMIN_API_VERSION=2026-04

# Google Ads metrics.
GOOGLE_ADS_API_VERSION=v24
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_OAUTH_CLIENT_ID=
GOOGLE_ADS_OAUTH_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=

# Amazon Ads metrics.
AMAZON_ADS_CLIENT_ID=
AMAZON_ADS_CLIENT_SECRET=
AMAZON_ADS_REFRESH_TOKEN=
AMAZON_ADS_PROFILE_ID=

# Amazon product/listing comparison.
AMAZON_SELLER_REFRESH_TOKEN=
AMAZON_SELLER_CLIENT_ID=
AMAZON_SELLER_CLIENT_SECRET=
# The API also accepts SP_API_REFRESH_TOKEN, SP_API_LWA_CLIENT_ID, and
# SP_API_LWA_CLIENT_SECRET from amazon-seller-pp-cli.
AMAZON_SELLER_MARKETPLACE_ID=

# Search Console metrics.
GOOGLE_SEARCH_CONSOLE_SITE_URL=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Future Meta tab.
META_AD_ACCOUNT_ID=
META_ACCESS_TOKEN=

# No LLM/API model calls are used by this dashboard.
