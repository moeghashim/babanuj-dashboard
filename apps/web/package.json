{
	"name": "@babanuj-dashboard/web",
	"version": "0.0.2",
	"private": true,
	"scripts": {
		"auth:generate": "better-auth generate --config ./lib/auth-config.ts --output ./lib/auth-generated-schema.ts -y",
		"auth:migrate": "better-auth migrate --config ./lib/auth-config.ts -y",
		"auth:push": "drizzle-kit push --config ./drizzle.config.ts",
		"clean": "rm -rf .next",
		"dev": "next dev",
		"build": "next build --webpack",
		"start": "next start",
		"check": "tsc -p tsconfig.json --noEmit"
	},
	"dependencies": {
		"@heroui/react": "^3.0.1",
		"@heroui/styles": "^3.0.1",
		"@libsql/client": "^0.17.2",
		"@tailwindcss/postcss": "^4.2.2",
		"better-auth": "^1.5.6",
		"convex": "^1.34.1",
		"drizzle-orm": "^0.45.2",
		"framer-motion": "^12.38.0",
		"next": "16.2.1",
		"next-themes": "^0.4.6",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"tailwindcss": "^4.2.2"
	},
	"devDependencies": {
		"@better-auth/cli": "^1.4.21",
		"@types/node": "^22.10.5",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"drizzle-kit": "^0.31.10",
		"typescript": "^5.9.2"
	},
	"engines": {
		"node": "22.x"
	}
}
